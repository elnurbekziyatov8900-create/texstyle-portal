<%- include('partials/header') %>

<div style="max-width:560px;margin:80px auto;padding:0 24px;text-align:center">
  <div class="form-card" style="text-align:center">
    <div class="mono" style="font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#7a7568">Care label · Error</div>
    <div style="font-family:'Archivo',sans-serif;font-weight:900;font-size:72px;color:var(--indigo);line-height:1;margin:14px 0 6px">
      <%= String(code).charAt(0) %><span style="color:var(--selvedge)"><%= String(code).charAt(1) %></span><%= String(code).charAt(2) %>
    </div>
    <p style="color:#5b6172;margin-bottom:28px"><%= message %></p>
    <a class="btn red" href="/">Bosh sahifaga</a>
  </div>
</div>

<%- include('partials/footer') %>
